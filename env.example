# Copier vers .env et remplir les valeurs. Ne jamais commiter .env.

DATABASE_URL="mysql://user:password@host:3306/dbname"
JWT_SECRET="votre-secret-jwt-long-et-aleatoire"

# Callback MTN Money : secret partagé pour vérifier la signature des webhooks (HMAC-SHA256).
# Si absent en production, le callback retournera 500.
MTN_CALLBACK_SECRET=""
